# =============================================================================
# BaroSmart / E-learning — DHAMMAAN variables-ka app-ku isticmaalo
# =============================================================================
# LOCAL:    copy this file → .env   (Windows: copy .env.example .env)
# VERCEL:   Project → Settings → Environment Variables (same keys & values)
#
# MUUHIIM:  Ha gelin fayl .env (qiimayaasha dhabta ah) GitHub — kaliya .env.example
# =============================================================================

# --- NextAuth v5 (WAA LAGUMA MAARMI KARO production) ---
# Sirta session-ka — samee: openssl rand -base64 32
AUTH_SECRET=

# Public website URL used for uploaded media and email links. Do not use localhost here.
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Auth callback URL. Use localhost only for local development; use your public domain in production.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- PostgreSQL + Prisma (WAA LAGUMA MAARMI KARO) ---
# Neon / VPS — isticmaal sslmode=require ama verify-full production
DATABASE_URL=

# --- Email sender (MFA security codes, dalabyada, iwm.) ---
# Gmail SMTP example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_FROM="BaroSmart <yourgmail@gmail.com>"
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional fallback: Resend. Not required if SMTP_* values above are configured.
RESEND_API_KEY=
# Cinwaanka "from" (haddii aan la dhigin waa onboarding@resend.dev)
RESEND_FROM=
# Email-ka admin (oo lagu ogeysiiyo dalabyada)
ADMIN_EMAIL=

# --- Kaliya gudubinta xogta hal mar (development) — HA KU DARIN Vercel ---
# OLD_DATABASE_URL=
