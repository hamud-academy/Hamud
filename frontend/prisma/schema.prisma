// BaroSmart E-Learning - Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ USERS ============
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  image        String?
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  enrollments       Enrollment[]
  createdCourses    Course[]           @relation("InstructorCourses")
  lessonCompletions LessonCompletion[]
  testimonies       Testimony[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

// ============ CATEGORIES ============
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now()) @map("created_at")

  courses Course[]

  @@index([name])
  @@map("categories")
}

// ============ COURSES ============
model Course {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String?
  thumbnail     String?
  price         Decimal     @default(0) @db.Decimal(10, 2)
  originalPrice Decimal?    @map("original_price") @db.Decimal(10, 2)
  level         CourseLevel @default(BEGINNER)
  language      String      @default("so")
  durationHours Decimal?    @map("duration_hours") @db.Decimal(5, 2)
  published     Boolean     @default(false)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  instructorId String @map("instructor_id")
  categoryId   String @map("category_id")

  instructor  User         @relation("InstructorCourses", fields: [instructorId], references: [id], onDelete: Cascade)
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  modules     Module[]
  enrollments Enrollment[]
  orders      Order[]

  @@index([published, createdAt])
  @@index([published, level, createdAt])
  @@index([categoryId, published, createdAt])
  @@index([instructorId, createdAt])
  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ============ MODULES (Chapters) ============
model Module {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  courseId String   @map("course_id")
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([courseId, order])
  @@map("modules")
}

// ============ LESSONS ============
model Lesson {
  id          String   @id @default(cuid())
  title       String
  videoUrl    String?  @map("video_url")
  documentUrl String?  @map("document_url") // PDF, Word, Excel (URL or uploaded file path)
  duration    Int? // minutes
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  moduleId    String             @map("module_id")
  module      Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
  lessonQuiz  LessonQuiz?

  @@index([moduleId, order])
  @@map("lessons")
}

// ============ LESSON QUIZ (multiple choice; one quiz per lesson) ============
model LessonQuiz {
  id        String               @id @default(cuid())
  lessonId  String               @unique @map("lesson_id")
  createdAt DateTime             @default(now()) @map("created_at")
  lesson    Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions LessonQuizQuestion[]

  @@map("lesson_quizzes")
}

model LessonQuizQuestion {
  id        String             @id @default(cuid())
  quizId    String             @map("quiz_id")
  order     Int                @default(0)
  prompt    String             @db.Text
  quiz      LessonQuiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options   LessonQuizOption[]

  @@index([quizId, order])
  @@map("lesson_quiz_questions")
}

model LessonQuizOption {
  id         String             @id @default(cuid())
  questionId String             @map("question_id")
  order      Int                @default(0)
  text       String             @db.Text
  isCorrect  Boolean            @default(false) @map("is_correct")
  question   LessonQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
  @@map("lesson_quiz_options")
}

// ============ LESSON COMPLETIONS (video dhammaystirkii) ============
model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completedAt])
  @@index([lessonId, completedAt])
  @@map("lesson_completions")
}

// ============ ENROLLMENTS ============
model Enrollment {
  id         String   @id @default(cuid())
  progress   Int      @default(0) // 0-100 percentage
  completed  Boolean  @default(false)
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  userId   String @map("user_id")
  courseId String @map("course_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, enrolledAt])
  @@index([courseId, enrolledAt])
  @@index([completed, updatedAt])
  @@index([enrolledAt])
  @@map("enrollments")
}

// ============ ORDERS (Checkout - lacag bixinta kadib admin u xaqiijiyaa) ============
model Order {
  id            String      @id @default(cuid())
  fullName      String      @map("full_name")
  email         String
  phone         String?
  country       String?
  address       String?
  region        String?     @map("region")
  postcode      String?
  paymentMethod String      @map("payment_method") // WaafiPay, EVC, Zaad, Manual, etc.
  paymentRef    String?     @map("payment_ref") // reference user sent
  amount        Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  paidAt        DateTime?   @map("paid_at")
  userId        String?     @map("user_id") // set when admin creates user after payment
  passwordHash  String?     @map("password_hash") // password ardaygu buuxiyay checkout (approve marka la isticmaalo)

  courseId String @map("course_id")
  course   Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([status, paidAt])
  @@index([courseId, status])
  @@index([userId])
  @@index([email])
  @@map("orders")
}

enum OrderStatus {
  PENDING // lacag weli ma timidin
  PAID // admin xaqiijiyay
}

// ============ TESTIMONIES (student testimony about the website) ============
model Testimony {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(200)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("testimonies")
}

// ============ SITE SETTINGS (favicon + browser tab title; singleton row) ============
model SiteSettings {
  id         String   @id @default("default")
  faviconUrl String?  @map("favicon_url")
  tabTitle   String?  @map("tab_title")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ============ APP CONFIGS (dynamic JSON configs) ============
model AppConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("app_configs")
}
